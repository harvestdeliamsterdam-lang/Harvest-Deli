# =============================================================================
# Harvest Deli — configuration reference
# =============================================================================
# IMPORTANT: this is a STATIC site (plain HTML/CSS/JS, no build step, no
# framework). Because there is no build, the browser cannot read process.env /
# Vercel Environment Variables at runtime. So these values are NOT consumed
# from Vercel env vars — they are edited directly in the config files noted
# below. This file is the canonical list of what needs filling in to go live
# with each integration.
#
# >>> To deploy the site to Vercel, NO environment variables are required. <<<
# The site runs fully on its built-in mock data; every integration below is
# OFF/placeholder by default and safely no-ops until configured.
# =============================================================================

# --- Public site URL (used in canonical tags, OG tags, sitemap.xml, robots) ---
# Currently hardcoded to https://harvestdeli.nl across the HTML + sitemap.xml +
# robots.txt. If the production domain changes, update those references.
SITE_URL=https://harvestdeli.nl

# --- Analytics (set in: commerce.js → GA4_ID / META_PIXEL_ID) ---
# Consent-gated; stays disabled while the placeholder values are present.
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
META_PIXEL_ID=0000000000

# --- Support (set in: commerce.js → WHATSAPP_NUMBER, intl format, no +) ---
WHATSAPP_NUMBER=31600000000

# --- Sanity CMS (set in: cms/config.js → config.sanity) ---
# Editorial/journal content. Site uses mock content until these are filled and
# config.source is switched to 'sanity'. See cms/README.md + sanity/.
SANITY_PROJECT_ID=REPLACE_WITH_PROJECT_ID
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01

# --- Shopify headless (set in: commerce/config.js → HD_COMMERCE_CONFIG.shopify) ---
# NOT installed yet. Storefront API seam is prepared (commerce/storefront.js).
# Site uses mock commerce until these are filled and source is switched to
# 'shopify'. // SEAM markers in commerce/ show exactly where to wire it.
SHOPIFY_STORE_DOMAIN=su08c4-v4.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=
SHOPIFY_API_VERSION=2024-10
